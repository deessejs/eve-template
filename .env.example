# Copy to `.env` and fill in real values for local development.
# On Vercel: set these in Project Settings → Environment Variables
# (Production + Preview), or use `vercel env pull` to populate `.env.local`.

# ─── Database ───────────────────────────────────────────────────────────
# Postgres connection string. Used by:
#   - db/index.ts (Drizzle)
#   - lib/auth.ts (better-auth drizzleAdapter)
#   - scripts/create-user.mjs (server-side createUser)
#
# Examples:
#   Local Docker: postgres://postgres:postgres@localhost:5432/eve_template
#   Vercel Postgres: postgres://default:<password>@<host>-pooler.us-east-1.postgres.vercel-storage.com:5432/verceldb?sslmode=verify-full
#   Neon:            postgres://<user>:<password>@<host>.neon.tech/neondb?sslmode=verify-full
DATABASE_URL=

# ─── better-auth ────────────────────────────────────────────────────────
# ≥32-char high-entropy secret used for cookie signing, password hashing
# salts, and CSRF tokens. Generate with:
#   openssl rand -base64 32
# Rotate safely using BETTER_AUTH_SECRETS (plural) — see better-auth docs.
BETTER_AUTH_SECRET=

# Public origin of this app. better-auth uses it for redirects, OAuth
# callbacks, and `allowedOrigins` checks. If unset, better-auth tries to
# derive it from the request — fine for most cases but explicit is safer.
#   Dev:  http://localhost:3000
#   Prod: https://your-deployment.vercel.app
BETTER_AUTH_URL=http://localhost:3000

# Mirror of BETTER_AUTH_URL for the browser-side authClient. Must be
# NEXT_PUBLIC_ prefixed to be inlined into the client bundle.
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000

# ─── MiniMax (M3 model for the eve agent) ──────────────────────────────
# API key for vercel-minimax-ai-provider. Default model is minimax() at
# `https://api.minimaxi.io/anthropic/v1` (Anthropic-compatible). Get a
# key at https://platform.minimax.io/ — the provider wraps MiniMax's
# direct API, no Vercel AI Gateway involved.
#
# Optional overrides if you want to point at a different MiniMax endpoint
# or use the OpenAI-compatible instance instead of the Anthropic one:
#   minimax: 'vercel-minimax-ai-provider' (Anthropic-compatible, default)
#   minimaxOpenAI: import { minimaxOpenAI } from 'vercel-minimax-ai-provider'
MINIMAX_API_KEY=
